# PostgreSQL (Prisma Migrate reads this via prisma.config.ts; runtime uses the same URL with @prisma/adapter-pg)
# Use 5435 when Docker maps db:5432 -> host:5435 (see docker-compose.port5435.yml). Port 5432 is often a local Postgres with different users.
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/mart?schema=public"

PORT=3005
NODE_ENV=development

# Step 3 — set a strong secret in production
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Seed (npm run prisma:seed) — creates one admin only; purges legacy @martdemo.com accounts
SEED_ADMIN_EMAIL=madhukar@techfylabs.com
SEED_ADMIN_PASSWORD=FlashMart@Admin2026
SEED_ADMIN_NAME=FlashMart Admin
SEED_COMPANY_NAME=FlashMart Distribution

# Email — Brevo (recommended: API key). Get it at app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=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
MAIL_FROM="FlashMart <madhukar@techfylabs.com>"
MAIL_APP_NAME=FlashMart
# Optional SMTP fallback (Brevo SMTP tab — login is often xxx@smtp-brevo.com, NOT your Gmail)
