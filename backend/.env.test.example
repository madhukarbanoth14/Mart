# Local TEST environment — copy to .env for day-to-day development.
# All local testing, Prisma Studio, and npm run start:dev should use this DB.
# Production releases use .env.production + Cloud SQL only (never copy into .env).
#
# Setup:
#   cp .env.test.example .env
#   npm run db:setup:test

DATABASE_URL="postgresql://postgres:postgres@localhost:5436/mart_test?schema=public"

PORT=3005
NODE_ENV=development
APP_ENV=test

SEED_ADMIN_EMAIL=you@example.com
SEED_ADMIN_PASSWORD=choose-a-strong-password-min-8-chars
SEED_ADMIN_NAME=FlashMart Admin
SEED_COMPANY_NAME=FlashMart Distribution

JWT_SECRET=local-dev-only-change-me
JWT_EXPIRES_IN=7d

# Razorpay TEST keys only in local/test
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

FCM_SERVER_KEY=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM="KNSR Mart <your@gmail.com>"
MAIL_APP_NAME=KNSR Mart
