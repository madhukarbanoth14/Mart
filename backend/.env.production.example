# Copy to .env.production (never commit). Used by deploy + prod-db-setup scripts.
#
# Production Postgres (Cloud SQL example — adjust for your instance):
# DATABASE_URL="postgresql://USER:PASSWORD@/mart?host=/cloudsql/PROJECT:asia-south1:INSTANCE&schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@PUBLIC_IP:5432/mart?schema=public"

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Dealer / shopkeeper onboarding confirmation emails (login email + password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM="KNSR Mart <your@gmail.com>"
MAIL_APP_NAME=KNSR Mart
