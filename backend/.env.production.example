# Copy to .env.production (never commit). Used by deploy + prod-db-setup scripts ONLY.
# Do NOT copy this into .env — local dev uses mart_test (see .env.test.example).
#
# App / seed scripts (Cloud Run uses MART_DATABASE_URL secret):
DATABASE_URL="postgresql://APP_USER:PASSWORD@PUBLIC_IP:5432/mart?schema=public"
#
# Migrations — MUST be the Postgres table owner (usually postgres on Cloud SQL).
# Prisma ALTER TABLE fails with "must be owner of table User" if you use APP_USER here.
MIGRATE_DATABASE_URL="postgresql://postgres:POSTGRES_PASSWORD@PUBLIC_IP:5432/mart?schema=public"

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Cloud Run loads DATABASE_URL + JWT from Secret Manager by default.
# Sync Razorpay keys before deploy:
#   ./scripts/sync-gcp-secrets.sh
#   ./scripts/deploy-cloud-run.sh

# Onboarding emails (employee/dealer/shopkeeper login + password)
# Brevo API — required for Cloud Run (recommended). Verify sender in Brevo → Settings → Senders.
BREVO_API_KEY=your-brevo-api-key
MAIL_FROM="FlashMart <your-verified-sender@yourdomain.com>"
MAIL_APP_NAME=FlashMart
# Optional SMTP fallback (Brevo: use BREVO_SMTP_LOGIN from dashboard, not your mailbox email)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# BREVO_SMTP_LOGIN=xxxx@smtp-brevo.com
# SMTP_PASS=your-brevo-smtp-key

# Registration OTP (Twilio Verify) — required on Cloud Run for self-signup
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Verify → Services → "My New Verify Service" → SID starts with VA
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMS_OTP_EXPIRY_MINUTES=10
