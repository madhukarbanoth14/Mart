# =============================================================================
# ENVIRONMENTS — test vs production
# =============================================================================
#
# TEST (local):  database mart_test  →  .env  (this file)
# PRODUCTION:    database mart        →  .env.production only (Cloud SQL, deploy scripts)
#
# Recommended local setup:
#   cp .env.test.example .env
#   npm run db:setup:test
#
# The API refuses to start in development if DATABASE_URL points at production Cloud SQL.
#
# =============================================================================
# DATABASE_URL — pick ONE approach
# =============================================================================
#
# Full troubleshooting (Docker I/O errors, P1010, port conflicts):
#   Mart/docs/database-troubleshooting.md
#
# A) Docker (matches default below; good for demos)
#    docker compose up -d
#    If Docker shows overlayfs/metadata.db "input/output error" → disk/Docker Desktop;
#    see database-troubleshooting.md (reset Docker or free disk space).
#
#    If port 5432 is busy: npm run db:up:5435
#    You MUST point Prisma at 5435 too — either:
#      - set DATABASE_URL below to ...localhost:5435/...  OR
#      - run: npm run prisma:migrate:deploy:docker5435 && npm run prisma:seed:docker5435
#
# B) Postgres already on your Mac (Homebrew, Postgres.app, etc.)
#    P1010 / "access denied" usually means wrong user/password or DB missing.
#    - Create DB:  createdb mart   OR   psql -U postgres -c 'CREATE DATABASE mart;'
#    - Use a URL your install accepts, e.g. trust auth:
#      postgresql://YOUR_USERNAME@localhost:5432/mart?schema=public
#    - Or set user/password to match how you configured PostgreSQL.
#
# =============================================================================
# Host port must match how you started Docker:
#   docker compose up -d              → 5432
#   npm run db:up:5435                → 5435 (Prisma P1001 on 5432 means .env still says 5432)
#
# If the Android/web app shows HTTP 500 on login (not 401), the API often cannot
# reach the DB: wrong port (e.g. .env still says 5432 while Docker is on 5435) or
# local Postgres on 5432 does not have user postgres → Prisma P1010.
# =============================================================================

# Default: plain docker compose on 5432
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mart?schema=public"

# Recommended: dedicated TEST database (npm run db:up:test / db:setup:test)
DATABASE_URL="postgresql://postgres:postgres@localhost:5436/mart_test?schema=public"

# Legacy local Docker on 5435 (database mart — prefer mart_test above)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5435/mart?schema=public"

PORT=3005
NODE_ENV=development
APP_ENV=test

# First-time seed — creates ONE admin only (no demo users). Required before: npm run prisma:seed
SEED_ADMIN_EMAIL=madhukar@techfylabs.com
SEED_ADMIN_PASSWORD=choose-a-strong-password-min-8-chars
SEED_ADMIN_NAME=FlashMart Admin
SEED_COMPANY_NAME=FlashMart Distribution


# Razorpay (use test keys in non-production)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# FCM — legacy server key (optional; push is skipped if unset)
FCM_SERVER_KEY=YOUR_FCM_KEY_HERE

# Email (SMTP) — required for dealer/shopkeeper onboarding confirmation emails
# Without these, approval still works but credentials are shown only in the admin app.
# Gmail: create an App Password → https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM="KNSR Mart <your@gmail.com>"
MAIL_APP_NAME=KNSR Mart

# SMS OTP (Twilio Verify) — required in production for self-registration
# Console → Verify → Services → copy Service SID (starts with VA…)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# Legacy optional: Programmable Messaging (MG…) if not using Verify
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_SMS_FROM=
SMS_OTP_EXPIRY_MINUTES=10
