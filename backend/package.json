{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:deploy:docker5435": "DATABASE_URL=postgresql://postgres:postgres@localhost:5435/mart?schema=public prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "seed": "ts-node prisma/seed.ts",
    "products:replace-from-sheet": "ts-node scripts/replace-products-from-sheet.ts",
    "products:replace-from-template-xls": "ts-node scripts/replace-products-from-sheet.ts ../product_upload_template.xls",
    "db:repair-product-bulk-shipping": "prisma db execute --file prisma/sql/ensure_product_bulk_shipping.sql",
    "db:seed-dealer-stock": "ts-node scripts/seed-dealer-stock.ts",
    "deploy:cloud-run": "bash scripts/deploy-cloud-run.sh",
    "prod:db-setup": "bash scripts/prod-db-setup.sh",
    "prisma:seed:docker5435": "DATABASE_URL=postgresql://postgres:postgres@localhost:5435/mart?schema=public prisma db seed",
    "db:up": "docker compose up -d",
    "db:up:arm64": "docker compose -f docker-compose.yml -f docker-compose.platform.arm64.yml up -d",
    "db:up:5435": "docker compose -f docker-compose.yml -f docker-compose.port5435.yml up -d",
    "db:up:5435:arm64": "docker compose -f docker-compose.yml -f docker-compose.port5435.yml -f docker-compose.platform.arm64.yml up -d",
    "db:up:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml up -d",
    "db:up:test:arm64": "docker compose -f docker-compose.yml -f docker-compose.test.yml -f docker-compose.platform.arm64.yml up -d",
    "db:setup:test": "bash scripts/db-setup-test.sh",
    "db:down:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml down",
    "db:logs:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml logs db --tail 100",
    "db:ps:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml ps -a",
    "prisma:studio:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5436/mart_test?schema=public prisma studio",
    "prisma:migrate:deploy:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5436/mart_test?schema=public prisma migrate deploy",
    "prisma:seed:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5436/mart_test?schema=public prisma db seed",
    "db:down": "docker compose down",
    "test:email": "node scripts/test-smtp.mjs",
    "test:sms": "node scripts/test-sms.mjs",
    "db:down:5435": "docker compose -f docker-compose.yml -f docker-compose.port5435.yml down",
    "db:logs": "docker compose logs db --tail 100",
    "db:logs:5435": "docker compose -f docker-compose.yml -f docker-compose.port5435.yml logs db --tail 100",
    "db:ps": "docker compose ps -a",
    "db:ps:5435": "docker compose -f docker-compose.yml -f docker-compose.port5435.yml ps -a"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.1",
    "nodemailer": "^8.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
