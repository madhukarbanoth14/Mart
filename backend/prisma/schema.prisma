// Retail Distribution Platform — PostgreSQL schema
// Multi-tenant ready: optional Company + nullable companyId on core entities.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ——— Enums ———

enum UserRole {
  ADMIN
  EMPLOYEE
  DEALER
  SHOPKEEPER
}

enum BrandType {
  OWN
  OTHER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  DELIVERED
}

// ——— SaaS foundation (optional tenant) ———

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users    User[]
  areas    Area[]
  products Product[]
  stocks   Stock[]
  orders   Order[]
  invoices Invoice[]
}

// ——— Core entities ———

model User {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  name     String
  email    String    @unique
  phone    String?
  password String
  role     UserRole

  /// Shopkeeper / employee home area; dealers typically resolve areas via Area.dealerId
  areaId String?
  area   Area?   @relation("UserArea", fields: [areaId], references: [id], onDelete: SetNull)

  /// Areas this dealer is assigned to fulfill
  dealerAreas Area[] @relation("AreaDealer")

  shopkeeperOrders Order[] @relation("ShopkeeperOrders")
  dealerOrders     Order[] @relation("DealerOrders")
  stocks           Stock[]

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([role])
  @@index([areaId])
}

model Area {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  name     String
  dealerId String
  dealer   User   @relation("AreaDealer", fields: [dealerId], references: [id], onDelete: Restrict)

  users User[] @relation("UserArea")

  @@index([companyId])
  @@index([dealerId])
}

model Product {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  name               String
  brandType          BrandType
  basePrice          Decimal   @db.Decimal(12, 2)
  /// GST % stored per product (e.g. 18.00)
  gstPercentage      Decimal   @db.Decimal(5, 2)
  /// Configurable % discount for dealer purchases on OWN brand (default business rule: 10)
  dealerDiscount     Decimal   @db.Decimal(5, 2)
  /// Configurable % discount for shopkeeper purchases on OWN brand (default: 5)
  shopkeeperDiscount Decimal   @db.Decimal(5, 2)

  createdAt DateTime @default(now())

  orderItems OrderItem[]
  stocks     Stock[]

  @@index([companyId])
  @@index([brandType])
}

model Stock {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  dealerId  String
  dealer    User    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity  Int
  updatedAt DateTime @updatedAt

  @@unique([dealerId, productId])
  @@index([companyId])
}

model Order {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  shopkeeperId String
  shopkeeper   User   @relation("ShopkeeperOrders", fields: [shopkeeperId], references: [id], onDelete: Restrict)
  dealerId     String
  dealer       User   @relation("DealerOrders", fields: [dealerId], references: [id], onDelete: Restrict)

  totalAmount    Decimal     @db.Decimal(12, 2)
  gstAmount      Decimal     @db.Decimal(12, 2)
  discountAmount Decimal     @db.Decimal(12, 2)
  finalAmount    Decimal     @db.Decimal(12, 2)
  status         OrderStatus @default(PENDING)

  createdAt DateTime @default(now())

  items   OrderItem[]
  invoice Invoice?

  @@index([companyId])
  @@index([shopkeeperId])
  @@index([dealerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity       Int
  /// Unit line price before GST (after role discount on line)
  price          Decimal @db.Decimal(12, 2)
  gstAmount      Decimal @db.Decimal(12, 2)
  discountAmount Decimal @db.Decimal(12, 2)
  finalAmount    Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  invoiceNumber String   @unique
  generatedAt   DateTime @default(now())
  pdfUrl        String?

  @@index([companyId])
  @@index([generatedAt])
}
