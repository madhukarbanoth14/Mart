// Retail Distribution Platform — PostgreSQL schema
// Multi-tenant ready: optional Company + nullable companyId on core entities.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ——— Enums ———

enum UserRole {
  ADMIN
  EMPLOYEE
  DEALER
  SHOPKEEPER
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  DEACTIVATED
}

enum BrandType {
  OWN
  OTHER
}

/// FMCG shelf taxonomy for shopkeeper catalog navigation.
enum ProductShelf {
  STAPLES
  OILS_GHEE
  SUGAR_SALT_BASICS
  BEVERAGES
  SNACKS_BISCUITS
  HOME_CARE
  PERSONAL_CARE
  MILK_DRINKS
  DETERGENTS
  FEMININE_BABY_CARE
  SHAMPOOS
  GENERAL_CARE
  ATTA
  BISCUITS_COOKIES
  NOODLES
  CHOCOLATES
  AGARBATTIS
  SOAPS
  STATIONERY
  COFFEE
  SAUCE
  EDIBLE_OIL
  NON_EDIBLE_OIL
}

enum OrderStatus {
  PENDING
  DEALER_CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

/// SHOPKEEPER: shopkeeper orders from assigned dealer. DEALER_RESTOCK: dealer orders from company warehouse.
enum OrderKind {
  SHOPKEEPER
  DEALER_RESTOCK
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

/// Aggregate document status for a dealer / shopkeeper account.
enum UserDocumentStatus {
  NOT_UPLOADED
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

/// Per-document verification state (employee review).
enum DocumentVerificationStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum BusinessDocumentType {
  AADHAAR
  PAN
  GST
  TRADE_LICENSE
}

// ——— SaaS foundation (optional tenant) ———

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users    User[]
  areas    Area[]
  brands   Brand[]
  products Product[]
  stocks   Stock[]
  orders   Order[]
  invoices Invoice[]
  payments Payment[]
  commissionRules CommissionRule[]
  platformRevenues PlatformRevenue[]
  dealerSettlements DealerSettlement[]
}

// ——— Core entities ———

model User {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  name     String
  email    String    @unique
  /// Unique when set; used for phone-first demo logins
  phone    String?   @unique
  password String
  role     UserRole

  /// One-time password reset token (returned to staff on onboard; dealer sets password via app).
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  /// FCM device token for push notifications (nullable until client registers)
  fcmToken String?

  /// Shopkeeper / employee home area; dealers typically resolve areas via Area.dealerId
  areaId String?
  area   Area?   @relation("UserArea", fields: [areaId], references: [id], onDelete: SetNull)

  /// Areas this dealer is assigned to fulfill
  dealerAreas Area[] @relation("AreaDealer")

  /// Areas this employee manages (for partner assignment).
  employeeAreas Area[] @relation("AreaEmployee")

  shopkeeperOrders Order[] @relation("ShopkeeperOrders")
  dealerOrders     Order[] @relation("DealerOrders")
  stocks           Stock[]

  /// Employee/admin who registered this user (onboarding).
  onboardedById   String?
  onboardedBy     User?    @relation("UserOnboarding", fields: [onboardedById], references: [id], onDelete: SetNull)
  usersOnboarded  User[]   @relation("UserOnboarding")

  onboardingNotes String?

  /// Shop / business display name shown to counterparties (keeps personal name private).
  shopName String?
  /// Postal address captured at onboarding (free text).
  address String?
  /// Captured GPS coordinates for delivery routing (optional).
  latitude  Float?
  longitude Float?

  /// Employee-set login password (encrypted) — emailed on admin approval, then cleared.
  approvalLoginPasswordEnc String? @map("approval_login_password_enc")

  status       UserStatus @default(ACTIVE)
  statusReason String?
  approvedById String?
  approvedBy   User?      @relation("UserApproval", fields: [approvedById], references: [id], onDelete: SetNull)
  usersApproved User[]    @relation("UserApproval")
  approvedAt   DateTime?

  onboardingDocuments OnboardingDocument[]

  /// Registration geography (self-service onboarding).
  state    String?
  district String?

  /// Employee referral code (employees only).
  referralCode String? @unique

  /// Cached flags — recomputed when documents change.
  documentUploaded Boolean            @default(false)
  canPlaceOrders   Boolean            @default(false)
  documentStatus   UserDocumentStatus @default(NOT_UPLOADED)

  lastFollowUpAt DateTime?

  documentsVerified OnboardingDocument[] @relation("DocumentVerifier")

  commissionRules CommissionRule[] @relation("DealerCommissionRules")
  platformRevenues PlatformRevenue[] @relation("DealerPlatformRevenues")
  dealerSettlements DealerSettlement[] @relation("DealerSettlements")
  dealerPayments DealerPaymentHistory[] @relation("DealerPaymentRecipient")
  financeAudits FinanceAuditLog[] @relation("FinanceAuditActor")
  returnRequestsAsShopkeeper ReturnRequest[] @relation("ReturnShopkeeper")
  returnRequestsAsDealer ReturnRequest[] @relation("ReturnDealer")
  refundRequestsAsDealer RefundRequest[] @relation("RefundDealer")
  refundRequestsProcessed RefundRequest[] @relation("RefundProcessor")
  settlementsCreated DealerSettlement[] @relation("SettlementCreator")
  paymentsRecorded DealerPaymentHistory[] @relation("PaymentRecorder")

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([role])
  @@index([areaId])
  @@index([onboardedById])
  @@index([status])
  @@index([documentStatus])
}

model OnboardingDocument {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  documentType BusinessDocumentType?
  fileName   String
  mimeType   String?
  storageKey String
  fileSize   Int?
  uploadedAt DateTime @default(now())

  verificationStatus DocumentVerificationStatus @default(PENDING_VERIFICATION)
  verifiedById       String?
  verifiedBy           User?    @relation("DocumentVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt           DateTime?
  rejectionReason      String?

  @@index([userId])
  @@index([verificationStatus])
}

model PhoneOtp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  purpose   String   @default("REGISTER")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, purpose])
}

model Area {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  name     String
  state    String?
  district String?

  dealerId String?
  dealer   User?   @relation("AreaDealer", fields: [dealerId], references: [id], onDelete: SetNull)

  /// Employee responsible for partners in this area.
  employeeId String?
  employee   User?   @relation("AreaEmployee", fields: [employeeId], references: [id], onDelete: SetNull)

  users User[] @relation("UserArea")

  @@index([companyId])
  @@index([dealerId])
  @@index([employeeId])
}

model Product {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  brandId   String?
  brand     Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  imageUrl  String?
  sku       String?  @unique
  weight    String   @default("")
  mrp       Decimal? @db.Decimal(12, 2)
  dealerPrice Decimal? @db.Decimal(12, 2)
  caseQty   Int?
  gstRate   Decimal  @default(5) @db.Decimal(5, 2)
  isActive  Boolean  @default(true)

  name               String
  brandType          BrandType
  shelf              ProductShelf @default(STAPLES)
  basePrice          Decimal   @db.Decimal(12, 2)
  /// GST % stored per product (e.g. 18.00)
  gstPercentage      Decimal   @db.Decimal(5, 2)
  /// Configurable % discount for dealer purchases on OWN brand (default business rule: 10)
  dealerDiscount     Decimal   @db.Decimal(5, 2)
  /// Configurable % discount for shopkeeper purchases on OWN brand (default: 5)
  shopkeeperDiscount Decimal   @db.Decimal(5, 2)

  /// Flat bulk shipping fee (once per line) when quantity meets minimum
  bulkShippingFee    Decimal?  @db.Decimal(12, 2)
  bulkShippingMinQty Int       @default(10)

  createdAt DateTime @default(now())

  orderItems OrderItem[]
  stocks     Stock[]
  commissionRules CommissionRule[] @relation("ProductCommissionRules")
  returnRequestItems ReturnRequestItem[]

  @@index([companyId])
  @@index([brandId])
  @@unique([name, weight])
  @@index([brandType])
  @@index([shelf])
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  manufacturer String?
  category  String?
  logoUrl   String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Stock {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  dealerId  String
  dealer    User    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity  Int
  updatedAt DateTime @updatedAt

  @@unique([dealerId, productId])
  @@index([companyId])
}

model Order {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  shopkeeperId String
  shopkeeper   User   @relation("ShopkeeperOrders", fields: [shopkeeperId], references: [id], onDelete: Restrict)
  dealerId     String
  dealer       User   @relation("DealerOrders", fields: [dealerId], references: [id], onDelete: Restrict)

  kind OrderKind @default(SHOPKEEPER)

  totalAmount    Decimal     @db.Decimal(12, 2)
  gstAmount      Decimal     @db.Decimal(12, 2)
  discountAmount Decimal     @db.Decimal(12, 2)
  finalAmount    Decimal     @db.Decimal(12, 2)
  status         OrderStatus @default(PENDING)
  paymentStatus  OrderPaymentStatus @default(UNPAID)
  returnReason       String?
  returnRequestedAt  DateTime?
  returnedAt         DateTime?
  refundedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     OrderItem[]
  invoice   Invoice?
  payments  Payment[]
  platformRevenue PlatformRevenue?
  returnRequests  ReturnRequest[]
  refundRequests  RefundRequest[]

  @@index([companyId])
  @@index([shopkeeperId])
  @@index([dealerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity       Int
  /// Unit line price before GST (after role discount on line)
  price          Decimal @db.Decimal(12, 2)
  gstAmount      Decimal @db.Decimal(12, 2)
  discountAmount Decimal @db.Decimal(12, 2)
  finalAmount    Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  invoiceNumber String   @unique
  generatedAt   DateTime @default(now())
  pdfUrl        String?

  @@index([companyId])
  @@index([generatedAt])
}

model Payment {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider PaymentProvider
  status   PaymentStatus   @default(INITIATED)

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("INR")

  gatewayOrderId   String? @unique
  gatewayPaymentId String?
  gatewaySignature String?
  gatewayRefundId  String?
  failureReason    String?
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  platformRevenues PlatformRevenue[]

  @@index([companyId])
  @@index([orderId])
  @@index([provider, status])
}

// ——— Finance & settlements ———

enum CommissionRuleType {
  GLOBAL
  DEALER
  PRODUCT
}

enum SettlementStatus {
  PENDING
  PARTIALLY_SETTLED
  SETTLED
}

enum SettlementPaymentMethod {
  BANK_TRANSFER
  UPI
  NEFT
  RTGS
  OTHER
}

enum FinanceAuditAction {
  COMMISSION_CALCULATED
  SETTLEMENT_CREATED
  SETTLEMENT_APPROVED
  SETTLEMENT_PAYMENT
  SETTLEMENT_MODIFIED
  COMMISSION_RULE_UPDATED
  REPORT_DOWNLOADED
  PAYMENT_UPDATED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_REJECTED
  REFUND_REQUESTED
  REFUND_APPROVED
  REFUND_REJECTED
  REFUND_PROCESSED
}

enum ReturnReason {
  DAMAGED_PRODUCT
  EXPIRED_PRODUCT
  WRONG_PRODUCT
  QUALITY_ISSUE
  EXCESS_QUANTITY
  OTHER
}

enum ReturnRequestStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  RETURN_COMPLETED
}

enum RefundRequestStatus {
  PENDING
  PROCESSING
  REFUNDED
  FAILED
  REJECTED
}

enum RefundMethod {
  RAZORPAY
  BANK_TRANSFER
  UPI
}

model CommissionRule {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  ruleType  CommissionRuleType
  rate      Decimal @db.Decimal(5, 2)
  dealerId  String?
  dealer    User?   @relation("DealerCommissionRules", fields: [dealerId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation("ProductCommissionRules", fields: [productId], references: [id], onDelete: Cascade)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([ruleType])
  @@index([dealerId])
  @@index([productId])
}

model PlatformRevenue {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  dealerId  String
  dealer    User     @relation("DealerPlatformRevenues", fields: [dealerId], references: [id], onDelete: Restrict)

  grossAmount       Decimal @db.Decimal(12, 2)
  gstAmount         Decimal @db.Decimal(12, 2)
  commissionAmount  Decimal @db.Decimal(12, 2)
  dealerPayable     Decimal @db.Decimal(12, 2)
  commissionRate    Decimal @db.Decimal(5, 2)

  settlementId     String?
  settlement       DealerSettlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)
  settlementStatus SettlementStatus  @default(PENDING)

  revenueDate DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([dealerId])
  @@index([settlementId])
  @@index([settlementStatus])
  @@index([revenueDate])
}

model DealerSettlement {
  id             String   @id @default(uuid())
  settlementCode String   @unique
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  dealerId String
  dealer   User   @relation("DealerSettlements", fields: [dealerId], references: [id], onDelete: Restrict)

  settlementStartDate DateTime
  settlementEndDate   DateTime

  totalOrders      Int     @default(0)
  totalQuantity    Int     @default(0)
  grossSales       Decimal @db.Decimal(14, 2)
  gstAmount        Decimal @db.Decimal(14, 2)
  commissionAmount Decimal @db.Decimal(14, 2)
  dealerPayable    Decimal @db.Decimal(14, 2)
  settledAmount    Decimal @default(0) @db.Decimal(14, 2)
  balanceAmount    Decimal @db.Decimal(14, 2)

  settlementStatus SettlementStatus @default(PENDING)
  paymentMethod    SettlementPaymentMethod?
  transactionReference String?
  utrNumber        String?
  paymentDate      DateTime?
  remarks          String?

  createdById String?
  createdBy   User?   @relation("SettlementCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revenues PlatformRevenue[]
  payments DealerPaymentHistory[]

  @@index([companyId])
  @@index([dealerId])
  @@index([settlementStatus])
  @@index([settlementStartDate, settlementEndDate])
}

model DealerPaymentHistory {
  id           String   @id @default(uuid())
  settlementId String
  settlement   DealerSettlement @relation(fields: [settlementId], references: [id], onDelete: Restrict)

  dealerId String
  dealer   User   @relation("DealerPaymentRecipient", fields: [dealerId], references: [id], onDelete: Restrict)

  amount               Decimal @db.Decimal(14, 2)
  paymentMethod        SettlementPaymentMethod
  transactionReference String?
  utrNumber            String?
  paymentDate          DateTime
  remarks              String?
  proofUrl             String?

  createdById String?
  createdBy   User?   @relation("PaymentRecorder", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([settlementId])
  @@index([dealerId])
  @@index([paymentDate])
}

model FinanceAuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  action     FinanceAuditAction
  entityType String
  entityId   String
  actorId    String?
  actor      User?    @relation("FinanceAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  details    Json?
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ReturnRequest {
  id             String              @id @default(uuid())
  companyId      String?
  returnCode     String              @unique
  orderId        String
  order          Order               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  shopkeeperId   String
  shopkeeper     User                @relation("ReturnShopkeeper", fields: [shopkeeperId], references: [id], onDelete: Restrict)
  dealerId       String
  dealer         User                @relation("ReturnDealer", fields: [dealerId], references: [id], onDelete: Restrict)
  reason         ReturnReason
  reasonText     String?
  comments       String?
  imageUrls      Json?
  status         ReturnRequestStatus @default(REQUESTED)
  dealerRemarks  String?
  refundAmount   Decimal             @db.Decimal(12, 2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  approvedAt     DateTime?
  rejectedAt     DateTime?
  completedAt    DateTime?

  items          ReturnRequestItem[]
  refundRequest  RefundRequest?

  @@index([orderId])
  @@index([shopkeeperId])
  @@index([dealerId])
  @@index([status])
  @@index([createdAt])
}

model ReturnRequestItem {
  id              String        @id @default(uuid())
  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItemId     String?
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName     String
  quantity        Int
  unitAmount      Decimal       @db.Decimal(12, 2)
  lineAmount      Decimal       @db.Decimal(12, 2)

  @@index([returnRequestId])
  @@index([productId])
}

model RefundRequest {
  id                   String              @id @default(uuid())
  companyId            String?
  refundCode           String              @unique
  returnRequestId      String              @unique
  returnRequest        ReturnRequest       @relation(fields: [returnRequestId], references: [id], onDelete: Restrict)
  orderId              String
  order                Order               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  dealerId             String
  dealer               User                @relation("RefundDealer", fields: [dealerId], references: [id], onDelete: Restrict)
  shopkeeperId         String
  amount               Decimal             @db.Decimal(12, 2)
  status               RefundRequestStatus @default(PENDING)
  dealerRemarks        String?
  adminRemarks         String?
  refundMethod         RefundMethod?
  transactionReference String?
  refundDate           DateTime?
  processedById        String?
  processedBy          User?               @relation("RefundProcessor", fields: [processedById], references: [id], onDelete: SetNull)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([orderId])
  @@index([dealerId])
  @@index([shopkeeperId])
  @@index([status])
  @@index([createdAt])
}
