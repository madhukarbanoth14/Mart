// Retail Distribution Platform — PostgreSQL schema
// Multi-tenant ready: optional Company + nullable companyId on core entities.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ——— Enums ———

enum UserRole {
  ADMIN
  EMPLOYEE
  DEALER
  SHOPKEEPER
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  DEACTIVATED
}

enum BrandType {
  OWN
  OTHER
}

/// FMCG shelf taxonomy for shopkeeper catalog navigation.
enum ProductShelf {
  STAPLES
  OILS_GHEE
  SUGAR_SALT_BASICS
  BEVERAGES
  SNACKS_BISCUITS
  HOME_CARE
  PERSONAL_CARE
  MILK_DRINKS
  DETERGENTS
  FEMININE_BABY_CARE
  SHAMPOOS
  GENERAL_CARE
  ATTA
  BISCUITS_COOKIES
  NOODLES
  CHOCOLATES
  AGARBATTIS
  SOAPS
  STATIONERY
  COFFEE
  SAUCE
  EDIBLE_OIL
  NON_EDIBLE_OIL
}

enum OrderStatus {
  PENDING
  DEALER_CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  FAILED
}

/// SHOPKEEPER: shopkeeper orders from assigned dealer. DEALER_RESTOCK: dealer orders from company warehouse.
enum OrderKind {
  SHOPKEEPER
  DEALER_RESTOCK
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
}

// ——— SaaS foundation (optional tenant) ———

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users    User[]
  areas    Area[]
  brands   Brand[]
  products Product[]
  stocks   Stock[]
  orders   Order[]
  invoices Invoice[]
  payments Payment[]
}

// ——— Core entities ———

model User {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  name     String
  email    String    @unique
  /// Unique when set; used for phone-first demo logins
  phone    String?   @unique
  password String
  role     UserRole

  /// One-time password reset token (returned to staff on onboard; dealer sets password via app).
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  /// FCM device token for push notifications (nullable until client registers)
  fcmToken String?

  /// Shopkeeper / employee home area; dealers typically resolve areas via Area.dealerId
  areaId String?
  area   Area?   @relation("UserArea", fields: [areaId], references: [id], onDelete: SetNull)

  /// Areas this dealer is assigned to fulfill
  dealerAreas Area[] @relation("AreaDealer")

  shopkeeperOrders Order[] @relation("ShopkeeperOrders")
  dealerOrders     Order[] @relation("DealerOrders")
  stocks           Stock[]

  /// Employee/admin who registered this user (onboarding).
  onboardedById   String?
  onboardedBy     User?    @relation("UserOnboarding", fields: [onboardedById], references: [id], onDelete: SetNull)
  usersOnboarded  User[]   @relation("UserOnboarding")

  onboardingNotes String?

  /// Employee-set login password (encrypted) — emailed on admin approval, then cleared.
  approvalLoginPasswordEnc String? @map("approval_login_password_enc")

  status       UserStatus @default(ACTIVE)
  statusReason String?
  approvedById String?
  approvedBy   User?      @relation("UserApproval", fields: [approvedById], references: [id], onDelete: SetNull)
  usersApproved User[]    @relation("UserApproval")
  approvedAt   DateTime?

  onboardingDocuments OnboardingDocument[]

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([role])
  @@index([areaId])
  @@index([onboardedById])
  @@index([status])
}

model OnboardingDocument {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  fileName   String
  mimeType   String?
  storageKey String
  fileSize   Int?
  uploadedAt DateTime @default(now())

  @@index([userId])
}

model Area {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  name     String
  dealerId String?
  dealer   User?   @relation("AreaDealer", fields: [dealerId], references: [id], onDelete: SetNull)

  users User[] @relation("UserArea")

  @@index([companyId])
  @@index([dealerId])
}

model Product {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  brandId   String?
  brand     Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  imageUrl  String?
  sku       String?  @unique
  weight    String   @default("")
  mrp       Decimal? @db.Decimal(12, 2)
  dealerPrice Decimal? @db.Decimal(12, 2)
  caseQty   Int?
  gstRate   Decimal  @default(5) @db.Decimal(5, 2)
  isActive  Boolean  @default(true)

  name               String
  brandType          BrandType
  shelf              ProductShelf @default(STAPLES)
  basePrice          Decimal   @db.Decimal(12, 2)
  /// GST % stored per product (e.g. 18.00)
  gstPercentage      Decimal   @db.Decimal(5, 2)
  /// Configurable % discount for dealer purchases on OWN brand (default business rule: 10)
  dealerDiscount     Decimal   @db.Decimal(5, 2)
  /// Configurable % discount for shopkeeper purchases on OWN brand (default: 5)
  shopkeeperDiscount Decimal   @db.Decimal(5, 2)

  /// Flat bulk shipping fee (once per line) when quantity meets minimum
  bulkShippingFee    Decimal?  @db.Decimal(12, 2)
  bulkShippingMinQty Int       @default(10)

  createdAt DateTime @default(now())

  orderItems OrderItem[]
  stocks     Stock[]

  @@index([companyId])
  @@index([brandId])
  @@unique([name, weight])
  @@index([brandType])
  @@index([shelf])
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  manufacturer String?
  category  String?
  logoUrl   String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Stock {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  dealerId  String
  dealer    User    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity  Int
  updatedAt DateTime @updatedAt

  @@unique([dealerId, productId])
  @@index([companyId])
}

model Order {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  shopkeeperId String
  shopkeeper   User   @relation("ShopkeeperOrders", fields: [shopkeeperId], references: [id], onDelete: Restrict)
  dealerId     String
  dealer       User   @relation("DealerOrders", fields: [dealerId], references: [id], onDelete: Restrict)

  kind OrderKind @default(SHOPKEEPER)

  totalAmount    Decimal     @db.Decimal(12, 2)
  gstAmount      Decimal     @db.Decimal(12, 2)
  discountAmount Decimal     @db.Decimal(12, 2)
  finalAmount    Decimal     @db.Decimal(12, 2)
  status         OrderStatus @default(PENDING)
  paymentStatus  OrderPaymentStatus @default(UNPAID)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     OrderItem[]
  invoice   Invoice?
  payments  Payment[]

  @@index([companyId])
  @@index([shopkeeperId])
  @@index([dealerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity       Int
  /// Unit line price before GST (after role discount on line)
  price          Decimal @db.Decimal(12, 2)
  gstAmount      Decimal @db.Decimal(12, 2)
  discountAmount Decimal @db.Decimal(12, 2)
  finalAmount    Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  invoiceNumber String   @unique
  generatedAt   DateTime @default(now())
  pdfUrl        String?

  @@index([companyId])
  @@index([generatedAt])
}

model Payment {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider PaymentProvider
  status   PaymentStatus   @default(INITIATED)

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("INR")

  gatewayOrderId   String? @unique
  gatewayPaymentId String?
  gatewaySignature String?
  failureReason    String?
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([orderId])
  @@index([provider, status])
}
