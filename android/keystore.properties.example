# Copy to Mart/android/keystore.properties (never commit). Create keystore:
#   keytool -genkey -v -keystore flashmart-upload.jks -keyalg RSA -keysize 2048 -validity 10000 -alias flashmart
storeFile=flashmart-upload.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=flashmart
keyPassword=YOUR_KEY_PASSWORD
