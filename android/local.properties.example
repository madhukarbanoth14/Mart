# Copy to `Mart/android/local.properties` and adjust.

# -----------------------------------------------------------------------------
# Production (Play Store / live API) — recommended
# -----------------------------------------------------------------------------
mart.use.local.demo.auth=false
mart.demo.mode=false
mart.api.base.url.release=https://mart-api-95628498734.asia-south1.run.app

# -----------------------------------------------------------------------------
# Developer: emulator → local Nest API
# -----------------------------------------------------------------------------
# mart.api.base.url=http://10.0.2.2:3005

# -----------------------------------------------------------------------------
# Investor demo APK only (offline login, no server)
# -----------------------------------------------------------------------------
# mart.use.local.demo.auth=true
# mart.demo.mode=true

