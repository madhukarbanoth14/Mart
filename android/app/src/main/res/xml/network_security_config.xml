<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 1: cleartext HTTP for local / LAN NestJS (emulator 10.0.2.2 or e.g. 192.168.x.x). Lock down for production. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
